{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "allowJs": true,
    "allowUnreachableCode": true,
    "lib": ["es2021"],
    "target": "es2021",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "noEmit": true,
    "module": "NodeNext"
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts"]
}
