{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "allowJs": true,
    "allowUnreachableCode": true,
    "lib": [
      "es2020"
    ],
    "target": "es2020",
    "moduleResolution": "node",
    "types": [
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "src/**/*.ts"
  ]
}
