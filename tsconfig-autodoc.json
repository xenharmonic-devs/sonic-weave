{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "incremental": false,
    "rootDir": "./",
    "outDir": ".temp",
    "allowJs": true,
    "allowUnreachableCode": true,
    "lib": ["es2021"],
    "target": "es2021",
    "resolveJsonModule": true,
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "types": ["node"]
  },
  "include": ["./package.json", "scripts/builtin-docs.ts", "scr/**/*.ts"]
}
