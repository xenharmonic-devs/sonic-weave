{
  "extends": "./node_modules/gts/tsconfig-google.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "incremental": false,
    "rootDir": "./src",
    "outDir": "dist",
    "allowJs": true,
    "allowUnreachableCode": true,
    "lib": [
      "es2021"
    ],
    "target": "es2021",
    "moduleResolution": "nodenext",
    "types": [
      "node"
    ],
    "module": "NodeNext"
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/__benchmarks__/**"
  ]
}
