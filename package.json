{
  "name": "sonic-weave",
  "version": "0.13.1",
  "author": "Lumi Pakkanen",
  "description": "The SonicWeave DSL for manipulating musical frequencies, ratios and equal temperaments",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenharmonic-devs/sonic-weave.git"
  },
  "bugs": {
    "url": "https://github.com/xenharmonic-devs/sonic-weave/issues"
  },
  "homepage": "https://github.com/xenharmonic-devs/sonic-weave#readme",
  "keywords": [
    "Microtonal",
    "Music",
    "Xenharmonic",
    "Scales",
    "Frequency",
    "Equal Temperament",
    "DSL"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/frostburn"
  },
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "sonic-weave": "bin/sonic-weave.js"
  },
  "scripts": {
    "lint": "gts lint",
    "clean": "gts clean",
    "compile-sw2-parser": "peggy --format es src/grammars/scale-workshop-2.pegjs -o src/scale-workshop-2-ast.js",
    "compile-chord-parser": "peggy --format es src/grammars/sonic-weave-chord.pegjs src/grammars/base.pegjs -o src/parser/sonic-weave-chord.js",
    "compile-sonic-weave-parser": "peggy --format es src/grammars/sonic-weave.pegjs src/grammars/mos.pegjs src/grammars/base.pegjs -o src/parser/sonic-weave-ast.js",
    "compile-paren-counter": "peggy --format es src/grammars/paren-counter.pegjs src/grammars/base.pegjs -o src/parser/paren-counter.js",
    "compile-parsers": "npm run compile-sonic-weave-parser && npm run compile-chord-parser && npm run compile-sw2-parser && npm run compile-paren-counter",
    "precompile": "npm run compile-parsers",
    "compile": "tsc",
    "fix": "gts fix",
    "prepare": "npm run compile && npm run bake-prelude",
    "pretest": "npm run compile",
    "posttest": "npm run lint",
    "test": "vitest",
    "prebench": "npm run compile",
    "bench": "vitest bench",
    "doc": "typedoc src/index.ts --name sonic-weave",
    "preautodoc": "npm run precompile && tsc -p tsconfig-autodoc.json",
    "autodoc": "node .temp/scripts/builtin-docs.js > documentation/BUILTIN.md",
    "preinspect-grammar": "npm run compile-sonic-weave-parser",
    "inspect-grammar": "node scripts/inspect-printable-ascii.js",
    "preinspect-random": "npm run compile-sonic-weave-parser",
    "inspect-random": "node scripts/inspect-random-programs.js",
    "bake-prelude": "node scripts/bake-prelude.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "gts": "^7.0.0",
    "peggy": "^5.1.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "moment-of-symmetry": "^0.10.0",
    "xen-dev-utils": "^0.13.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "commander": "^12.1.0"
  },
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ast": {
      "types": "./dist/ast.d.ts",
      "import": "./dist/ast.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./css-colors": {
      "types": "./dist/css-colors.d.ts",
      "import": "./dist/css-colors.js"
    },
    "./diamond-mos": {
      "types": "./dist/diamond-mos.d.ts",
      "import": "./dist/diamond-mos.js"
    },
    "./expression": {
      "types": "./dist/expression.d.ts",
      "import": "./dist/expression.js"
    },
    "./fjs": {
      "types": "./dist/fjs.d.ts",
      "import": "./dist/fjs.js"
    },
    "./interval": {
      "types": "./dist/interval.d.ts",
      "import": "./dist/interval.js"
    },
    "./monzo": {
      "types": "./dist/monzo.d.ts",
      "import": "./dist/monzo.js"
    },
    "./pythagorean": {
      "types": "./dist/pythagorean.d.ts",
      "import": "./dist/pythagorean.js"
    },
    "./scale-workshop-2-parser": {
      "types": "./dist/scale-workshop-2-parser.d.ts",
      "import": "./dist/scale-workshop-2-parser.js"
    },
    "./temper": {
      "types": "./dist/temper.d.ts",
      "import": "./dist/temper.js"
    },
    "./tools": {
      "types": "./dist/tools.d.ts",
      "import": "./dist/tools.js"
    },
    "./warts": {
      "types": "./dist/warts.d.ts",
      "import": "./dist/warts.js"
    },
    "./words": {
      "types": "./dist/words.d.ts",
      "import": "./dist/words.js"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser/index.js"
    },
    "./stdlib": {
      "types": "./dist/stdlib/index.d.ts",
      "import": "./dist/stdlib/index.js"
    },
    "./package.json": "./package.json"
  }
}
